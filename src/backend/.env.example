# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Server
PORT=5000
FRONTEND_URL=http://localhost:1234

# Auth — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-string

# Google Gemini — get your free key at https://aistudio.google.com
GEMINI_API_KEY=AIza...

# SerpAPI — for LIVE competitor rate data from Google Hotels (100 free searches/month)
# Get free key at https://serpapi.com/register
# Without this key the app uses realistic demo data instead
SERPAPI_KEY=
