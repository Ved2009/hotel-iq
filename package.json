{
  "name": "hotel-iq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:frontend": "cd src/frontend && npm start",
    "build:frontend": "cd src/frontend && npm run build",
    "start:backend": "cd src/backend && node server.js",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\""
  },
  "dependencies": {
    "concurrently": "^7.6.0",
    "express": "^4.18.2"
  },
  "engines": {
    "node": ">=14"
  }
}
